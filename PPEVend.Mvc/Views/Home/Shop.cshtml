@model IList<string>
@{
    ViewData["Title"] = "Shop";
}

<div class="text-center">
    <h1 class="pulse-text m-4">Select Item</h1>
    <div class="d-flex flex-column  justify-content-start">
        <div class="row justify-content-center">
            <div class="col-8 col-md-8">
                <!-- Underline Display Area -->
                <div id="pin-display" class="d-flex justify-content-center gap-2 mb-1 p-3 text-light" style="height: 100px;">
                    <span class="display-1 fw-bold border-bottom border-5 border-light px-3 text-light" style="width:64px; font-size: 4rem;"></span>
                    <span class="display-1 fw-bold border-bottom border-5 border-light px-3 text-light" style="width:64px; font-size: 4rem;"></span>
                    <span class="display-1 fw-bold border-bottom border-5 border-light px-3 text-light" style="width:64px; font-size: 4rem;"></span>
                </div>

                <!-- Square Keypad Grid -->
                <div class="row g-3 row-cols-3">
                    <!-- Rows 1 to 3 -->
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">1</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">2</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">3</button></div>

                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">4</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">5</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">6</button></div>

                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">7</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">8</button></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">9</button></div>

                    <!-- Row 4 -->
                    <div class="col d-flex justify-content-center align-items-center ps-0 pt-3"><a asp-action="Shop" asp-controller="Home" class="text-light w-100 fw-bold text-decoration-none" style="height: 100px; font-size: 2.4rem;">Clear</a></div>
                    <div class="col"><button class="btn btn-primary w-100 rounded-3 num-btn shadow-sm border border-light border-2" style="height: 100px; font-size: 3rem;">0</button></div>
                </div>
            </div>

            <div class="row px-3 ms-1 fixed-bottom d-flex align-items-center" style="padding-right:20px;">
                <a asp-action="Index" asp-controller="Home" type="button" class="btn btn-danger rounded-3 p-2 fw-bold col-6 fs-1">Cancel Sale</a>
                <div class="col-3 ms-auto text-light position-relative">
                    <a asp-action="Cart" asp-controller="Home" class="text-decoration-none text-light">
                        <i class="bi bi-cart4" style="font-size: 100px;"></i>
                        <span id="itemBadge" class="position-absolute top-50 start-50 translate-middle badge rounded-pill bg-danger fs-1">
                            @Model.Count()
                        </span>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
</div>

<script>
    let pin = "";
    const slots = document.querySelectorAll('#pin-display span');

    document.querySelectorAll('.num-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (pin.length < 3) {
          pin += btn.innerText;
          render();
        }
      });
    });

    function render() {
      slots.forEach((slot, i) => {
        slot.innerText = pin[i] || "";
        // Optional: Add a class if filled
        pin[i] ? slot.classList.remove('text-muted') : slot.classList.add('text-muted');
      });
      if (pin.length >= 3) {
        // Use Url.Action to generate the correct MVC URL server-side
        var url = '@Url.Action("Cart", "Home")';

        // Redirect the browser
        setTimeout(() => {
            window.location.href = url + '/' + pin;
        }, 300);
      }
    }

</script>
